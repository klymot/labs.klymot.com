  <!-- Theme toggle + Reset lab wiring -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('themeToggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'light' ? 'dark' : 'light';
          if (next === 'dark') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
          }
          localStorage.setItem('klymot-theme', next);
        });
      }

      var reset = document.getElementById('resetLab');
      if (reset) {
        reset.addEventListener('click', function () {
          ['klymot-station-order-v1','klymot-res-order-v1','klymot-temp-order-v1','klymot-cmp-order-v1'].forEach(function(k) {
            try { localStorage.removeItem(k); } catch (_) {}
          });
          window.location.href = window.location.pathname;
        });
      }
    }());
  </script>

  <script is:inline>
    // ── CSS var helper ─────────────────────────────────────────────
    function cssVar(name) {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    // ── URL state ──────────────────────────────────────────────────
    function readStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      return {
        station:    params.get('s')   || null,
        dataType:   params.get('t')   || null,
        resolution: params.get('r')   || null,
        comparison: params.get('cmp') || null,
        lag:         params.has('lag') ? parseFloat(params.get('lag'))       : null,
        windowStart: params.has('ws')  ? parseInt(params.get('ws'),  10)     : null,
        windowSize:  params.has('wz')  ? parseInt(params.get('wz'),  10)     : null
      };
    }

    function pushStateToUrl() {
      if (!currentStation) {
        window.history.replaceState(null, '', window.location.pathname);
        return;
      }
      const params = new URLSearchParams();
      params.set('s', currentStation);
      if (currentDataType)     params.set('t',   currentDataType);
      if (currentResolution)   params.set('r',   currentResolution);
      if (currentComparison)   params.set('cmp', currentComparison);
      if (monthLag !== 0)        params.set('lag', String(monthLag));
      if (timeWindowStart !== 0) params.set('ws',  String(timeWindowStart));
      if (timeWindowSize !== null) params.set('wz', String(timeWindowSize));
      window.history.replaceState(null, '', `${window.location.pathname}?${params.toString()}`);
    }

    // ── Globals ────────────────────────────────────────────────────
    const KLYMOT_DATA_BASE = 'https://www.klymot.com/data';

    const STATION_META = {
      DAV: { name: 'Davos, Switzerland',            since: 1909, caveat: 'High-altitude site (1590 m); temperature is paired to the nearest long-span station, not Davos itself.' },
      TOK: { name: 'Tokyo, Japan',                  since: 1931, caveat: 'Strong urban heat island signal, especially in minimum temperatures.' },
      POT: { name: 'Potsdam, Germany',              since: 1937, caveat: 'Near the Berlin conurbation; urban land-use change affects temperature trends independently of sunshine.' },
      UCL: { name: 'Uccle, Belgium',                since: 1951, caveat: 'Urban Brussels location; RMIB national reference station.' },
      VAL: { name: 'Valentia Observatory, Ireland', since: 1954, caveat: 'Atlantic maritime climate; sea-surface temperatures partially decouple local temperature from sunshine variability.' },
      DBL: { name: 'De Bilt, Netherlands',          since: 1957, caveat: 'KNMI national reference station; open flat terrain representative of temperate maritime lowland.' },
      STO: { name: 'Stockholm, Sweden',             since: 1960, caveat: 'Urban station with a growing heat island signal; radiation records before the 1960s are from a different site.' },
    };

    let stations = {};
    let currentStation    = null;
    let currentDataType   = null;
    let currentResolution = null;
    let currentComparison = null;
    let monthLag = 0;
    let timeWindowStart = 0;
    let timeWindowSize = null;
    let timeSeriesChart = null;
    let scatterChart = null;

    // ── Utilities ──────────────────────────────────────────────────
    function setStatus(msg) {
      const el = document.getElementById('loadStatus');
      if (el) el.textContent = msg;
    }

    function monthKey(year, month) {
      return `${year}-${String(month).padStart(2, '0')}`;
    }

    function mean(values) {
      const valid = values.filter(Number.isFinite);
      return valid.length ? valid.reduce((s, v) => s + v, 0) / valid.length : null;
    }

    function clamp(value, lo, hi) {
      return Math.max(lo, Math.min(hi, value));
    }

    function addMonths(year, month, offset) {
      const z = year * 12 + (month - 1) + offset;
      return { year: Math.floor(z / 12), month: (z % 12) + 1 };
    }

    // ── Temperature loading ────────────────────────────────────────
    function klymotCsvUrl(kind, id) {
      return `${KLYMOT_DATA_BASE}/${kind}/${id}.csv`;
    }

    async function fetchText(url) {
      const r = await fetch(url);
      if (!r.ok) throw new Error(`${r.status} ${url}`);
      return r.text();
    }

    function parseKlymotMonthlyCsv(text) {
      const pts = new Map();
      text.trim().split(/\r?\n/).forEach(line => {
        const p = line.split(',');
        const yr = Number(p[0]);
        if (!Number.isFinite(yr)) return;
        for (let i = 1; i <= 12; i++) {
          const raw = p[i];
          if (raw === undefined || raw === '') continue;
          const v = Number(raw);
          if (!Number.isFinite(v) || v <= -9000) continue;
          pts.set(monthKey(yr, i), v / 100);
        }
      });
      return pts;
    }

    async function loadTemperatureSeries(station) {
      const [qcuText, qcfText] = await Promise.all([
        fetchText(klymotCsvUrl('qcu', station.tempStation.id)),
        fetchText(klymotCsvUrl('qcf', station.tempStation.id))
      ]);
      station.temperature = {
        qcu: parseKlymotMonthlyCsv(qcuText),
        qcf: parseKlymotMonthlyCsv(qcfText)
      };
    }

    async function ensureCurrentTemperatureLoaded() {
      const s = stations[currentStation];
      if (!s || s.temperature) return;
      setStatus(`Loading temperature for ${s.tempStation.id}…`);
      await loadTemperatureSeries(s);
      setStatus(`Loaded ${s.tempStation.id} temperature.`);
    }

    // ── Station data loading (manifest + per-station) ──────────────
    async function loadManifest() {
      const r = await fetch('data/manifest.json', { cache: 'no-store' });
      if (!r.ok) throw new Error(`${r.status} data/manifest.json`);
      return r.json();
    }

    async function loadStationFile(key) {
      const r = await fetch(`data/${key}.json`, { cache: 'no-store' });
      if (!r.ok) throw new Error(`${r.status} data/${key}.json`);
      return r.json();
    }

    function buildStation(record) {
      return {
        key: record.key,
        name: record.name,
        lat: record.lat,
        lon: record.lon,
        source: record.source || 'shortwave radiation',
        sunshineMonthly: record.monthly || [],
        tempStation: record.temperature_station,
        temperature: null
      };
    }

    // ── Station UI ─────────────────────────────────────────────────
    function shuffleArray(arr) {
      const a = arr.slice();
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    const STATION_KEYS = ['DAV', 'TOK', 'POT', 'UCL', 'VAL', 'DBL', 'STO'];
    const LS_ORDER_KEY = 'klymot-station-order-v1';

    function getStationOrder() {
      try {
        const stored = localStorage.getItem(LS_ORDER_KEY);
        if (stored) {
          const parsed = JSON.parse(stored);
          if (Array.isArray(parsed) && parsed.length === STATION_KEYS.length &&
              STATION_KEYS.every(k => parsed.includes(k))) {
            return parsed;
          }
        }
      } catch (_) {}
      const order = shuffleArray(STATION_KEYS);
      try { localStorage.setItem(LS_ORDER_KEY, JSON.stringify(order)); } catch (_) {}
      return order;
    }

    const stationCardOrder = getStationOrder();

    function renderStationCards() {
      const grid = document.getElementById('stationGrid');
      if (!grid) return;
      grid.innerHTML = '';
      stationCardOrder.forEach(key => {

        const meta = STATION_META[key];
        if (!meta) return;
        const loaded = !!stations[key];
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = ['station-card', key === currentStation ? 'active' : '', !loaded ? 'pending' : ''].filter(Boolean).join(' ');
        btn.setAttribute('aria-pressed', key === currentStation ? 'true' : 'false');
        btn.innerHTML = `<span class="sc-since">from ${meta.since}</span><span class="sc-name">${meta.name}</span><span class="sc-caveat">${loaded ? meta.caveat : 'Data not yet available — will be loaded on next refresh.'}</span>`;
        if (loaded) btn.addEventListener('click', () => selectStation(key));
        grid.appendChild(btn);
      });
    }

    function updateStationInfo() {
      const el = document.getElementById('stationInfo');
      const s = stations[currentStation];
      if (!el || !s) return;
      const dist = Number(s.tempStation.distance_km || 0).toFixed(1);
      el.innerHTML = `<span class="station-pill">${s.tempStation.id}</span><span class="station-dist">${s.tempStation.name}, ${dist} km</span>`;
    }

    function setPrompt(chosen) {
      const prompt = document.getElementById('selectPrompt');
      if (!prompt) return;
      if (chosen) {
        const meta = STATION_META[currentStation];
        prompt.textContent = `You chose: ${meta ? meta.name : currentStation}`;
        prompt.setAttribute('data-chosen', '');
      } else {
        prompt.textContent = 'Select a station above to explore the data.';
        prompt.removeAttribute('data-chosen');
      }
    }

    function deselectStation() {
      currentStation    = null;
      currentResolution = null;
      currentDataType   = null;
      currentComparison = null;
      revealToCurrentState();
      renderStationCards();
      updateStationInfo();
      pushStateToUrl();
    }

    async function selectStation(key) {
      if (key === currentStation) { deselectStation(); return; }
      currentStation = key;
      resetTimeWindow();
      renderStationCards();
      updateStationInfo();
      revealToCurrentState();
      pushStateToUrl();
      await ensureCurrentTemperatureLoaded();
      if (currentResolution && currentDataType && currentComparison) updateAllVisuals();
    }

    // ── Blocking choice constants ──────────────────────────────────
    const RESOLUTION_OPTIONS = [
      { value: 'monthly', name: 'Monthly', desc: 'Compare radiation and temperature month by month. The shared seasonal cycle — both peak in summer, dip in winter — makes the correlation immediately visible. Be aware that what you\'re mostly seeing is the season, not year-to-year climate variation.' },
      { value: 'yearly',  name: 'Annual',  desc: 'Average each year into a single value. The seasonal cycle disappears, leaving only year-to-year variation. This is a harder test — without the seasonal scaffold, you\'ll need to think carefully about what\'s left.' }
    ];

    const TEMP_OPTIONS = [
      { value: 'qcu', name: 'Raw (unadjusted)', desc: 'The station\'s original measured values. These may include non-climatic jumps from station relocations, instrument changes, or shifts in observation time.' },
      { value: 'qcf', name: 'PHA-adjusted',      desc: 'The pairwise homogeneity algorithm (PHA) compares each station against its neighbours and flags apparent non-climatic breakpoints. Adjustments are automated — the algorithm assigns corrections based on the majority of neighbouring stations.' }
    ];

    const COMP_OPTIONS = [
      { value: 'direct',  name: 'Direct',  desc: 'Compare the actual measured values. In monthly data the seasonal cycle dominates and the radiation–temperature relationship is clear. In annual data the seasonal scaffold is gone — direct annual values often show a weaker or noisier relationship because year-to-year swings are small compared to the seasonal range.' },
      { value: 'anomaly', name: 'Anomaly', desc: 'Each value is expressed as its departure from the long-term average for that calendar month (e.g. January 2020 minus the mean of all Januarys in the loaded record). This removes the seasonal cycle. In annual data, anomalies often reveal the year-to-year radiation–temperature link that direct comparison obscures.' }
    ];

    function getChoiceOrder(lsKey, items) {
      try {
        const stored = localStorage.getItem(lsKey);
        if (stored) {
          const parsed = JSON.parse(stored);
          const vals = items.map(i => i.value);
          if (Array.isArray(parsed) && parsed.length === vals.length && vals.every(v => parsed.includes(v))) {
            return parsed;
          }
        }
      } catch (_) {}
      const order = shuffleArray(items.map(i => i.value));
      try { localStorage.setItem(lsKey, JSON.stringify(order)); } catch (_) {}
      return order;
    }

    function renderChoiceGrid(gridId, options, lsKey, currentValue, onSelect) {
      const grid = document.getElementById(gridId);
      if (!grid) return;
      const order = getChoiceOrder(lsKey, options);
      grid.innerHTML = '';
      order.forEach(function(value) {
        const opt = options.find(o => o.value === value);
        if (!opt) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'station-card' + (value === currentValue ? ' active' : '');
        btn.setAttribute('aria-pressed', value === currentValue ? 'true' : 'false');
        btn.innerHTML = '<span class="sc-name">' + opt.name + '</span><span class="sc-caveat">' + opt.desc + '</span>';
        btn.addEventListener('click', function() { onSelect(value); });
        grid.appendChild(btn);
      });
    }

    function updateComparePrompt() {
      const el = document.getElementById('comparePrompt');
      if (!el) return;
      const resLabels = { monthly: 'Monthly', yearly: 'Annual' };
      const tmpLabels = { qcu: 'Raw (unadjusted)', qcf: 'PHA-adjusted' };
      const cmpLabels = { direct: 'Direct measurements', anomaly: 'Anomalies' };

      if (currentResolution && currentDataType && currentComparison) {
        el.textContent = 'You chose: ' + resLabels[currentResolution] + ' · ' + tmpLabels[currentDataType] + ' · ' + cmpLabels[currentComparison];
        el.setAttribute('data-chosen', '');
        return;
      }

      el.removeAttribute('data-chosen');

      const chosen = [];
      if (currentResolution) chosen.push(resLabels[currentResolution]);
      if (currentDataType)   chosen.push(tmpLabels[currentDataType]);
      if (currentComparison) chosen.push(cmpLabels[currentComparison]);

      const missing = [];
      if (!currentResolution) missing.push('a time resolution');
      if (!currentDataType)   missing.push('a temperature record');
      if (!currentComparison) missing.push('a comparison type');

      if (chosen.length === 0) {
        el.textContent = 'Choose one time resolution, one temperature record, and one comparison type to continue.';
      } else {
        const chosenStr  = 'You chose: ' + chosen.join(' · ') + '.';
        const missingStr = 'Still need: ' + missing.join(', ') + '.';
        el.textContent   = chosenStr + ' ' + missingStr;
      }
    }

    function revealToCurrentState() {
      const cmpSection = document.getElementById('compareSection');
      const labContent = document.getElementById('labContent');

      if (!currentStation) {
        if (cmpSection) cmpSection.hidden = true;
        if (labContent) labContent.hidden = true;
        setPrompt(false);
        return;
      }

      setPrompt(true);

      if (cmpSection) cmpSection.hidden = false;
      renderChoiceGrid('resolutionGrid', RESOLUTION_OPTIONS, 'klymot-res-order-v1', currentResolution, selectResolution);
      renderChoiceGrid('tempGrid', TEMP_OPTIONS, 'klymot-temp-order-v1', currentDataType, selectDataType);
      renderChoiceGrid('compGrid', COMP_OPTIONS, 'klymot-cmp-order-v1', currentComparison, selectComparison);
      updateComparePrompt();

      if (labContent) labContent.hidden = !(currentResolution && currentDataType && currentComparison);
    }

    function selectResolution(value) {
      if (value === currentResolution) {
        currentResolution = null;
      } else {
        currentResolution = value;
        resetTimeWindow();
      }
      revealToCurrentState();
      if (currentResolution && currentDataType && currentComparison) updateAllVisuals();
      pushStateToUrl();
    }

    function selectDataType(value) {
      currentDataType = (value === currentDataType) ? null : value;
      revealToCurrentState();
      if (currentResolution && currentDataType && currentComparison) updateAllVisuals();
      pushStateToUrl();
    }

    function selectComparison(value) {
      currentComparison = (value === currentComparison) ? null : value;
      revealToCurrentState();
      if (currentResolution && currentDataType && currentComparison) updateAllVisuals();
      pushStateToUrl();
    }

    function shiftLag(delta) {
      monthLag = clamp(Math.round((monthLag + delta) * 4) / 4, -2, 2);
      updateAllVisuals();
      pushStateToUrl();
    }

    function resetTimeWindow() {
      timeWindowStart = 0;
      timeWindowSize = null;
    }

    function resetTimeAxis() {
      const data = getCurrentData();
      timeWindowStart = 0;
      timeWindowSize = data.rows.length || null;
      updateTimeSeriesChart();
      pushStateToUrl();
    }

    // ── Data processing ────────────────────────────────────────────
    function fallbackLaggedMonthlySunshine(monthlyRows, lagMonths) {
      const rounded = Math.round(lagMonths);
      const buckets = new Map();
      monthlyRows.forEach(row => {
        const shifted = addMonths(row.year, row.month, -rounded);
        buckets.set(monthKey(shifted.year, shifted.month), row);
      });
      return buckets;
    }

    function alignMonthlyData(station) {
      const tempMap = station.temperature[currentDataType];
      const sunshineByMonth = fallbackLaggedMonthlySunshine(station.sunshineMonthly, monthLag);
      const rows = [];
      [...tempMap.keys()].sort().forEach(key => {
        const sw = sunshineByMonth.get(key);
        const temp = tempMap.get(key);
        if (!sw || !Number.isFinite(temp) || !Number.isFinite(sw.shortwave_mj_m2)) return;
        const [yr, mo] = key.split('-').map(Number);
        rows.push({
          key,
          label: key,
          year: yr,
          month: mo,
          temp,
          shortwave: sw.shortwave_mj_m2,
          days: sw.days
        });
      });
      return rows;
    }

    function aggregateYearly(monthlyRows) {
      const isAnomaly = currentComparison === 'anomaly';
      const byYear = new Map();
      monthlyRows.forEach(row => {
        if (!byYear.has(row.year)) byYear.set(row.year, []);
        byYear.get(row.year).push(row);
      });
      return [...byYear.entries()].sort((a, b) => a[0] - b[0]).map(([year, rows]) => ({
        key: String(year),
        label: String(year),
        year,
        temp:      mean(rows.map(r => r.temp)),
        shortwave: isAnomaly
          ? mean(rows.map(r => r.shortwave))
          : rows.reduce((s, r) => s + (r.shortwave || 0), 0),
        monthCount: rows.length
      })).filter(r => r.monthCount >= 9 && Number.isFinite(r.temp) && Number.isFinite(r.shortwave));
    }

    function computeMonthlyClimatology(rows) {
      const swSums  = new Array(13).fill(0), swCounts  = new Array(13).fill(0);
      const tSums   = new Array(13).fill(0), tCounts   = new Array(13).fill(0);
      rows.forEach(function(row) {
        const m = row.month;
        if (!m) return;
        swSums[m] += row.shortwave; swCounts[m]++;
        tSums[m]  += row.temp;      tCounts[m]++;
      });
      return {
        shortwave: swSums.map(function(s, i) { return swCounts[i] ? s / swCounts[i] : 0; }),
        temp:      tSums.map(function(s, i)  { return tCounts[i]  ? s / tCounts[i]  : 0; })
      };
    }

    function applyComparison(monthlyRows) {
      if (currentComparison !== 'anomaly') return monthlyRows;
      const clim = computeMonthlyClimatology(monthlyRows);
      return monthlyRows.map(function(row) {
        return Object.assign({}, row, {
          shortwave: row.shortwave - (clim.shortwave[row.month] || 0),
          temp:      row.temp      - (clim.temp[row.month]      || 0)
        });
      });
    }

    function ensureTimeWindow(rows) {
      if (!rows.length) { timeWindowStart = 0; timeWindowSize = 0; return; }
      const defaultSize = currentResolution === 'monthly' ? Math.min(rows.length, 12 * 20) : Math.min(rows.length, 40);
      if (!timeWindowSize || timeWindowSize > rows.length) timeWindowSize = defaultSize;
      timeWindowSize = clamp(timeWindowSize, currentResolution === 'monthly' ? 24 : 10, rows.length);
      timeWindowStart = clamp(timeWindowStart, 0, Math.max(0, rows.length - timeWindowSize));
    }

    function zoomTime(direction) {
      const data = getCurrentData();
      const total = data.rows.length;
      if (!total) return;
      ensureTimeWindow(data.rows);
      const factor = direction > 0 ? 0.7 : 1.4;
      const minSize = currentResolution === 'monthly' ? 24 : 10;
      const center = timeWindowStart + timeWindowSize / 2;
      timeWindowSize = clamp(Math.round(timeWindowSize * factor), minSize, total);
      timeWindowStart = clamp(Math.round(center - timeWindowSize / 2), 0, Math.max(0, total - timeWindowSize));
      updateTimeSeriesChart();
      pushStateToUrl();
    }

    function panTime(direction) {
      const data = getCurrentData();
      if (!data.rows.length) return;
      ensureTimeWindow(data.rows);
      const step = Math.max(1, Math.round(timeWindowSize * 0.25));
      timeWindowStart = clamp(timeWindowStart + direction * step, 0, Math.max(0, data.rows.length - timeWindowSize));
      updateTimeSeriesChart();
      pushStateToUrl();
    }

    function visibleTimeRows(rows) {
      ensureTimeWindow(rows);
      return rows.slice(timeWindowStart, timeWindowStart + timeWindowSize);
    }

    function yearTickStep(rows) {
      if (!rows.length) return 1;
      const span = Math.max(1, rows[rows.length - 1].year - rows[0].year);
      const rawStep = Math.ceil(span / 6);
      return [1, 2, 5, 10, 20, 25, 50].find(s => s >= rawStep) || 100;
    }

    function timeAxisLabel(row, rows) {
      if (!row) return '';
      const step = yearTickStep(rows);
      const firstYear = rows[0]?.year || row.year;
      if ((row.year - firstYear) % step !== 0) return '';
      if (currentResolution === 'monthly' && row.month !== 1) return '';
      return String(row.year);
    }

    function updateControlsReadout(rows) {
      const lagEl = document.getElementById('lagReadout');
      if (lagEl) lagEl.textContent = monthLag === 0 ? '0 mo' : `${monthLag > 0 ? '+' : ''}${monthLag} mo`;
      const readout = document.getElementById('timeWindowReadout');
      if (!readout || !rows.length) return;
      const visible = visibleTimeRows(rows);
      readout.textContent = visible.length ? `Visible: ${visible[0].label} to ${visible[visible.length - 1].label}` : '';
    }

    function getCurrentData() {
      const s = stations[currentStation];
      if (!s || !s.temperature) return { labels: [], sunshine: [], rows: [], station: s };
      const monthly   = alignMonthlyData(s);
      const processed = applyComparison(monthly);
      const rows      = currentResolution === 'monthly' ? processed : aggregateYearly(processed);
      updateControlsReadout(rows);
      return {
        labels:   rows.map(r => r.label),
        sunshine: rows.map(r => r.shortwave),
        rows,
        station: s
      };
    }

    // ── Chart rendering ────────────────────────────────────────────
    function updateTimeSeriesChart() {
      const container = document.getElementById('timeSeriesChart');
      if (!container) return;
      const data = getCurrentData();
      const rows = visibleTimeRows(data.rows);

      if (timeSeriesChart) { timeSeriesChart.destroy(); timeSeriesChart = null; }

      if (!rows.length) {
        container.innerHTML = '<p style="text-align:center;color:var(--muted);padding:2rem;font-size:.85rem">No overlapping data in this view.</p>';
        return;
      }

      const isAnomalyTS = currentComparison === 'anomaly';
      timeSeriesChart = new KlymotChart.DualAxisChart(container);
      timeSeriesChart.load({
        labels:      rows.map(r => r.label),
        leftData:    rows.map(r => r.temp),
        rightData:   rows.map(r => r.shortwave),
        leftLabel:   isAnomalyTS ? 'Temp anomaly (°C)'    : 'Temp (°C)',
        rightLabel:  isAnomalyTS ? 'SW anomaly (MJ/m²)'   : 'MJ/m²',
        leftColor:   cssVar('--success'),
        rightColor:  cssVar('--accent-primary'),
        labelFilter: (label, index) => timeAxisLabel(rows[index], rows)
      });
    }

    function updateScatterChart() {
      const container = document.getElementById('scatterChart');
      if (!container) return;
      const data = getCurrentData();

      if (scatterChart) { scatterChart.destroy(); scatterChart = null; }

      const points = data.rows.map((row, i) => ({
        x: data.sunshine[i],
        y: row.temp,
        label: row.label
      }));
      const fit = regressionFit(points);

      const isAnomalySC = currentComparison === 'anomaly';
      scatterChart = new KlymotChart.ScatterChart(container);
      scatterChart.load({
        points,
        fitLine:    fit.points.length >= 2 ? { points: fit.points } : null,
        xLabel:     isAnomalySC ? 'Shortwave anomaly (MJ/m²)' : 'Shortwave radiation (MJ/m²)',
        yLabel:     isAnomalySC ? 'Temperature anomaly (°C)'  : 'Temperature (°C)',
        pointColor: cssVar('--accent-primary'),
        fitColor:   cssVar('--success')
      });

      const noteEl = document.getElementById('scatterNote');
      if (noteEl) {
        noteEl.innerHTML = `Fit: y = ${fit.slope.toFixed(4)}x ${fit.intercept < 0 ? '−' : '+'} ${Math.abs(fit.intercept).toFixed(2)}. Lag: ${monthLag === 0 ? '0' : `${monthLag > 0 ? '+' : ''}${monthLag}`} month(s).`;
      }

      const badge = document.getElementById('resolutionBadge');
      if (badge) {
        const modeLabel = currentComparison === 'anomaly' ? 'anomalies' : 'pairs';
        badge.textContent = currentResolution === 'monthly' ? ('Monthly ' + modeLabel) : ('Annual ' + modeLabel);
      }
    }

    function regressionFit(points) {
      const valid = points.filter(p => Number.isFinite(p.x) && Number.isFinite(p.y));
      if (valid.length < 2) return { slope: 0, intercept: 0, points: [] };
      const mX = mean(valid.map(p => p.x));
      const mY = mean(valid.map(p => p.y));
      let num = 0, den = 0;
      valid.forEach(p => { num += (p.x - mX) * (p.y - mY); den += (p.x - mX) ** 2; });
      const slope = den ? num / den : 0;
      const intercept = mY - slope * mX;
      const xs = valid.map(p => p.x);
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      return {
        slope, intercept,
        points: [{ x: minX, y: slope * minX + intercept }, { x: maxX, y: slope * maxX + intercept }]
      };
    }

    function calculateCorrelation() {
      const data = getCurrentData();
      const n = data.rows.length;
      if (n < 3) return { r: NaN, r2: NaN, p: 'n/a' };
      let mX = 0, mY = 0;
      for (let i = 0; i < n; i++) { mX += data.sunshine[i]; mY += data.rows[i].temp; }
      mX /= n; mY /= n;
      let num = 0, dX = 0, dY = 0;
      for (let i = 0; i < n; i++) {
        const dx = data.sunshine[i] - mX;
        const dy = data.rows[i].temp - mY;
        num += dx * dy; dX += dx * dx; dY += dy * dy;
      }
      const r = num / Math.sqrt(dX * dY);
      const r2 = r * r;
      const t = r * Math.sqrt((n - 2) / (1 - r2));
      const p = 2 * (1 - Math.abs(t) / (Math.abs(t) + 2));
      return {
        r: parseFloat(r.toFixed(3)),
        r2: parseFloat(r2.toFixed(3)),
        p: p < 0.001 ? '<0.001' : p.toFixed(3)
      };
    }

    function updateCorrelationMetrics() {
      const corr = calculateCorrelation();
      document.getElementById('pearsonR').textContent = Number.isFinite(corr.r) ? corr.r : '—';
      document.getElementById('rSquared').textContent = Number.isFinite(corr.r2) ? corr.r2 : '—';
      document.getElementById('pValue').textContent = corr.p;
      const scoreEl = document.getElementById('contributionScore');
      if (!scoreEl) return;
      let text, color;
      if (!Number.isFinite(corr.r)) {
        text = 'Not enough overlapping paired observations'; color = 'var(--warning)';
      } else if (corr.r > 0.7) {
        text = `Strong positive contribution (r = ${corr.r})`; color = 'var(--success)';
      } else if (corr.r > 0.4) {
        text = `Moderate positive contribution (r = ${corr.r})`; color = 'var(--warning)';
      } else if (corr.r > 0) {
        text = `Weak positive contribution (r = ${corr.r})`; color = 'var(--warning)';
      } else {
        text = `Weak or negative relationship (r = ${corr.r})`; color = 'var(--danger)';
      }
      scoreEl.textContent = text;
      scoreEl.style.color = color;
    }

    function updateAllVisuals() {
      updateTimeSeriesChart();
      updateScatterChart();
      updateCorrelationMetrics();
    }

    // ── Network chart (Section 2) ──────────────────────────────────
    async function loadAndDrawNetworkChart() {
      const canvas = document.getElementById('networkChartCanvas');
      const loading = document.getElementById('networkChartLoading');
      if (!canvas) return;

      try {
        const [countsResp, histResp] = await Promise.all([
          fetch('data/pyranometer-network-counts.json'),
          fetch('data/pyranometer-network-history.json')
        ]);
        if (!countsResp.ok) throw new Error(`HTTP ${countsResp.status}`);
        const countsPayload = await countsResp.json();
        const histPayload = histResp.ok ? await histResp.json() : { milestones: [] };

        const series = countsPayload.series || [];
        const milestones = histPayload.milestones || [];

        if (loading) loading.remove();

        const meta = document.getElementById('networkChartMeta');
        if (meta && series.length) {
          const last = series[series.length - 1];
          meta.textContent = `${last.active_stations} active stations as of ${last.year}`;
        }

        let xOfYear = () => 0;

        function redraw() {
          xOfYear = drawNetworkChart(canvas, series, milestones);
        }

        redraw();
        wireNetworkTooltip(canvas, () => xOfYear, milestones);

        window.addEventListener('resize', redraw, { passive: true });

      } catch (err) {
        if (loading) loading.textContent = `Could not load: ${err.message}`;
      }
    }

    function drawNetworkChart(canvas, series, milestones) {
      const container = canvas.parentElement;
      const W = container.offsetWidth || 600;
      const H = container.offsetHeight || 220;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      const gold = '#d4a855';
      const textColor = cssVar('--text-secondary') || '#a8a090';
      const gridColor = 'rgba(212,168,85,0.12)';
      const pad = { top: 16, right: 20, bottom: 36, left: 52 };
      const cW = W - pad.left - pad.right;
      const cH = H - pad.top - pad.bottom;

      const years = series.map(d => d.year);
      const counts = series.map(d => d.active_stations);
      const minYear = Math.min(...years);
      const maxYear = Math.max(...years);
      const maxCount = Math.max(...counts);

      // Returns CSS pixel x position for a given year (used by tooltip hit-test)
      function xp(year) {
        return pad.left + (year - minYear) / Math.max(1, maxYear - minYear) * cW;
      }
      function yp(count) {
        return pad.top + cH - (count / maxCount) * cH;
      }

      ctx.clearRect(0, 0, W, H);

      // Grid lines
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      for (let i = 0; i <= 4; i++) {
        const y = pad.top + (cH / 4) * i;
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left + cW, y); ctx.stroke();
      }

      // Y axis labels
      ctx.fillStyle = textColor;
      ctx.font = '11px system-ui, sans-serif';
      ctx.textAlign = 'right';
      for (let i = 0; i <= 4; i++) {
        const c = Math.round(maxCount - (maxCount / 4) * i);
        const y = pad.top + (cH / 4) * i;
        ctx.fillText(c, pad.left - 8, y + 4);
      }

      // X axis labels
      ctx.textAlign = 'center';
      const xStep = Math.ceil((maxYear - minYear) / 6 / 10) * 10 || 10;
      for (let y = Math.ceil(minYear / xStep) * xStep; y <= maxYear; y += xStep) {
        ctx.fillText(y, xp(y), H - 8);
      }

      // Milestone vertical lines (dashed)
      milestones.forEach(m => {
        if (m.year < minYear || m.year > maxYear) return;
        const x = xp(m.year);
        ctx.save();
        ctx.setLineDash([3, 4]);
        ctx.strokeStyle = 'rgba(212,168,85,0.35)';
        ctx.lineWidth = 1.25;
        ctx.beginPath();
        ctx.moveTo(x, pad.top);
        ctx.lineTo(x, pad.top + cH);
        ctx.stroke();
        ctx.restore();
      });

      // Area fill
      ctx.fillStyle = 'rgba(212,168,85,0.07)';
      ctx.beginPath();
      ctx.moveTo(xp(years[0]), pad.top + cH);
      series.forEach(d => ctx.lineTo(xp(d.year), yp(d.active_stations)));
      ctx.lineTo(xp(years[years.length - 1]), pad.top + cH);
      ctx.closePath();
      ctx.fill();

      // Main line
      ctx.strokeStyle = gold;
      ctx.lineWidth = 2.5;
      ctx.lineJoin = 'round';
      ctx.setLineDash([]);
      ctx.beginPath();
      series.forEach((d, i) => {
        if (i === 0) ctx.moveTo(xp(d.year), yp(d.active_stations));
        else ctx.lineTo(xp(d.year), yp(d.active_stations));
      });
      ctx.stroke();

      return xp; // expose coordinate function for tooltip hit-test
    }

    function wireNetworkTooltip(canvas, getXOfYear, milestones) {
      const tooltip = document.getElementById('networkChartTooltip');
      if (!tooltip || !milestones.length) return;

      function hitTest(clientX) {
        const rect = canvas.getBoundingClientRect();
        const x = clientX - rect.left;
        const threshold = 14;
        let best = null, bestDist = Infinity;
        const xOf = getXOfYear();
        milestones.forEach(m => {
          const dist = Math.abs(x - xOf(m.year));
          if (dist < threshold && dist < bestDist) { best = m; bestDist = dist; }
        });
        return best;
      }

      function showTooltip(clientX, clientY, milestone) {
        const rect = canvas.getBoundingClientRect();
        const x = clientX - rect.left;
        const y = clientY - rect.top;
        tooltip.textContent = `${milestone.year}: ${milestone.event}`;
        tooltip.removeAttribute('hidden');
        const ttW = Math.min(280, rect.width * 0.7);
        let left = x + 14;
        if (left + ttW > rect.width - 8) left = x - ttW - 14;
        tooltip.style.left = Math.max(4, left) + 'px';
        tooltip.style.top = Math.max(4, Math.min(y - 8, rect.height - 80)) + 'px';
        tooltip.style.maxWidth = ttW + 'px';
      }

      function hideTooltip() {
        tooltip.setAttribute('hidden', '');
      }

      canvas.addEventListener('mousemove', e => {
        const hit = hitTest(e.clientX);
        if (hit) showTooltip(e.clientX, e.clientY, hit);
        else hideTooltip();
      });

      canvas.addEventListener('mouseleave', hideTooltip);

      canvas.addEventListener('touchstart', e => {
        e.preventDefault();
        const touch = e.touches[0];
        const hit = hitTest(touch.clientX);
        if (hit) showTooltip(touch.clientX, touch.clientY, hit);
      }, { passive: false });

      canvas.addEventListener('touchend', () => {
        setTimeout(hideTooltip, 2200);
      }, { passive: true });
    }

    // ── Initialization ─────────────────────────────────────────────
    async function initialize() {
      // Restore URL state
      const urlState = readStateFromUrl();
      if (urlState.station) currentStation = urlState.station;
      if (urlState.dataType === 'qcu' || urlState.dataType === 'qcf') currentDataType = urlState.dataType;
      if (urlState.resolution === 'monthly' || urlState.resolution === 'yearly') currentResolution = urlState.resolution;
      if (urlState.comparison === 'direct' || urlState.comparison === 'anomaly') currentComparison = urlState.comparison;
      if (urlState.lag !== null && Number.isFinite(urlState.lag)) monthLag = clamp(Math.round(urlState.lag * 4) / 4, -2, 2);
      if (urlState.windowStart !== null && Number.isFinite(urlState.windowStart)) timeWindowStart = Math.max(0, urlState.windowStart);
      if (urlState.windowSize !== null && Number.isFinite(urlState.windowSize)) timeWindowSize = Math.max(1, urlState.windowSize);

      // Network chart runs in parallel with station loading
      loadAndDrawNetworkChart();

      // Load stations from manifest
      setStatus('Loading station list…');
      let manifest;
      try {
        manifest = await loadManifest();
      } catch (err) {
        setStatus(`Could not load manifest: ${err.message}`);
        return;
      }

      // Load all per-station files (parallel, ~5 small files)
      try {
        await Promise.all(manifest.stations.map(async key => {
          const record = await loadStationFile(key);
          stations[key] = buildStation(record);
        }));
      } catch (err) {
        setStatus(`Could not load station data: ${err.message}`);
        return;
      }

      if (!Object.keys(stations).length) {
        setStatus('No stations found in manifest.');
        return;
      }

      // Only fall back if a URL-specified station doesn't exist in the manifest
      if (currentStation && !stations[currentStation]) currentStation = null;

      renderStationCards();
      updateStationInfo();

      if (currentStation) {
        await ensureCurrentTemperatureLoaded();
      }
      revealToCurrentState();
      if (currentStation && currentResolution && currentDataType && currentComparison) {
        updateAllVisuals();
      } else {
        setStatus('');
      }
      pushStateToUrl();

      console.log('%c[Sunshine-Temp Lab] initialized.', 'color:#a8a090');
    }

    window.onload = () => initialize().catch(err => {
      console.error(err);
      setStatus(`Could not load data: ${err.message}`);
    });
  </script>
</body>
</html>
