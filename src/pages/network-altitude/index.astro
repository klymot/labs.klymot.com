  <!-- ── JavaScript ──────────────────────────────────────────────────────── -->
  <script is:inline>
  (function () {
    'use strict';

    /* ── Constants ─────────────────────────────────────────────────── */
    const ELR = 0.0065;  // °C per metre (environmental lapse rate, ISA standard)
    const AGGREGATE_URL = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
      ? '/api/v1/aggregate'
      : 'https://api.klymot.com/api/v1/aggregate';
    const DATA_BASE = 'data';  // relative to the page

    const BASELINE_RANGES = {
      '1700-1729': [1700, 1729],
      '1730-1759': [1730, 1759],
      '1760-1789': [1760, 1789],
      '1790-1819': [1790, 1819],
      '1820-1849': [1820, 1849],
      '1850-1879': [1850, 1879],
      '1880-1909': [1880, 1909],
      '1910-1939': [1910, 1939],
      '1940-1969': [1940, 1969],
      '1970-1999': [1970, 1999],
      '2000-2029': [2000, 2029],
    };

    const PREDICTION_OPTIONS = [
      {
        key: 'warming',
        label: 'A warming signal',
        desc: 'The average elevation fell; cooler high-altitude stations dropped out, making the network appear warmer.',
      },
      {
        key: 'cooling',
        label: 'A cooling signal',
        desc: 'The average elevation rose; more cold, high-altitude stations joined, making the network appear cooler.',
      },
      {
        key: 'negligible',
        label: 'Negligible effect',
        desc: 'The altitude changes are too small to produce a meaningful temperature signal.',
      },
      {
        key: 'mixed',
        label: 'It changed direction',
        desc: 'The network climbed in some periods and fell in others, creating a mixed signal over time.',
      },
    ];

    /* ── State ─────────────────────────────────────────────────────── */
    let altitudeData   = null;   // {annual: [{year, mean_elev_m, median_elev_m, n}]}
    let observedDataBySeries = { qcu: null, qcf: null };
    let stationIds     = null;   // cached so series switch doesn't reload the file
    let predictionKey  = null;
    let baseline       = '2000-2029';
    let observedRawVisible      = false;
    let observedAdjustedVisible = false;
    let seriesModel             = true;
    let visitBeaconSent = false;
    let predBeaconSent  = false;
    let modelBeaconSent = false;
    let compBeaconSent  = false;

    /* ── Utility ───────────────────────────────────────────────────── */
    function cssVar(name) {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    function mean(arr) {
      if (!arr.length) return NaN;
      return arr.reduce((s, v) => s + v, 0) / arr.length;
    }

    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

    /* ── URL state ─────────────────────────────────────────────────── */
    function readStateFromUrl() {
      const hash = location.hash.slice(1);
      const params = new URLSearchParams(hash);
      return {
        prediction: params.get('prediction') || null,
        baseline:   params.get('baseline')   || null,
        series:     params.get('series')     || null,
        obs:        params.get('obs')        || null,
      };
    }

    function pushStateToUrl() {
      const params = new URLSearchParams();
      params.set('v', '1');
      if (predictionKey) params.set('prediction', predictionKey);
      params.set('baseline', baseline);
      const obs = [
        observedRawVisible ? 'qcu' : null,
        observedAdjustedVisible ? 'qcf' : null,
      ].filter(Boolean);
      params.set('obs', obs.length ? obs.join(',') : 'none');
      params.set('series', seriesModel ? 'model' : 'none');
      const hash = '#' + params.toString();
      if (location.hash !== hash) history.replaceState(null, '', hash);
    }

    /* ── Altitude chart ────────────────────────────────────────────── */
    function drawAltitudeChart(annual) {
      const container = document.getElementById('altitudeChartContainer');
      if (!container) return;

      // Remove old canvas if redrawing
      const old = container.querySelector('canvas');
      if (old) old.remove();

      const canvas = document.createElement('canvas');
      canvas.style.cssText = 'display:block;width:100%;height:100%;cursor:crosshair';
      canvas.setAttribute('role', 'img');
      container.prepend(canvas);

      const tooltip = document.getElementById('altitudeTooltip');
      const meta    = document.getElementById('altitudeChartMeta');

      function draw() {
        const W = container.clientWidth || 600;
        const H = container.clientHeight || 220;
        const dpr = window.devicePixelRatio || 1;
        canvas.width  = Math.round(W * dpr);
        canvas.height = Math.round(H * dpr);
        canvas.style.width  = W + 'px';
        canvas.style.height = H + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const gold       = cssVar('--accent') || '#d4a855';
        const textColor  = cssVar('--text-secondary') || '#a8a090';
        const gridColor  = 'rgba(212,168,85,0.12)';
        const pad = { top: 16, right: 24, bottom: 36, left: 56 };
        const cW = W - pad.left - pad.right;
        const cH = H - pad.top - pad.bottom;

        const years  = annual.map(d => d.year);
        const elevs  = annual.map(d => d.mean_elev_m);
        const minYr  = Math.min(...years);
        const maxYr  = Math.max(...years);
        const minEl  = Math.min(...elevs);
        const maxEl  = Math.max(...elevs);
        const pad_el = (maxEl - minEl) * 0.08 || 10;
        const loEl   = minEl - pad_el;
        const hiEl   = maxEl + pad_el;

        function xp(yr) { return pad.left + (yr - minYr) / Math.max(1, maxYr - minYr) * cW; }
        function yp(el) { return pad.top + (1 - (el - loEl) / (hiEl - loEl)) * cH; }

        ctx.clearRect(0, 0, W, H);

        // Grid
        ctx.strokeStyle = gridColor;
        ctx.lineWidth = 1;
        for (let i = 0; i <= 4; i++) {
          const y = pad.top + (cH / 4) * i;
          ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left + cW, y); ctx.stroke();
        }

        // Y axis labels
        ctx.fillStyle = textColor;
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'right';
        for (let i = 0; i <= 4; i++) {
          const el = hiEl - (hiEl - loEl) * (i / 4);
          ctx.fillText(Math.round(el) + ' m', pad.left - 6, pad.top + (cH / 4) * i + 4);
        }

        // X axis labels
        ctx.textAlign = 'center';
        const xStep = Math.ceil((maxYr - minYr) / 6 / 20) * 20 || 20;
        for (let yr = Math.ceil(minYr / xStep) * xStep; yr <= maxYr; yr += xStep) {
          ctx.fillText(yr, xp(yr), H - 8);
        }

        // Area fill
        ctx.fillStyle = 'rgba(212,168,85,0.07)';
        ctx.beginPath();
        ctx.moveTo(xp(years[0]), pad.top + cH);
        annual.forEach(d => ctx.lineTo(xp(d.year), yp(d.mean_elev_m)));
        ctx.lineTo(xp(years[years.length - 1]), pad.top + cH);
        ctx.closePath();
        ctx.fill();

        // Main line
        ctx.strokeStyle = gold;
        ctx.lineWidth = 2;
        ctx.lineJoin = 'round';
        ctx.setLineDash([]);
        ctx.beginPath();
        annual.forEach((d, i) => {
          if (i === 0) ctx.moveTo(xp(d.year), yp(d.mean_elev_m));
          else ctx.lineTo(xp(d.year), yp(d.mean_elev_m));
        });
        ctx.stroke();

        if (meta) meta.textContent = `${minYr}–${maxYr}`;
        return xp;
      }

      let getXp = draw();
      new ResizeObserver(() => { getXp = draw(); }).observe(container);

      // Tooltip
      canvas.addEventListener('mousemove', e => {
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        // Find nearest year
        const xpFn = getXp;
        let best = null, bestDist = Infinity;
        annual.forEach(d => {
          const dx = Math.abs(x - xpFn(d.year));
          if (dx < bestDist) { bestDist = dx; best = d; }
        });
        if (best && bestDist < 30 && tooltip) {
          tooltip.textContent = `${best.year}  ${best.mean_elev_m.toFixed(1)} m  (months=${best.n})`;
          tooltip.removeAttribute('hidden');
          const ttW = tooltip.offsetWidth || 180;
          let left = x + 14;
          if (left + ttW > rect.width - 8) left = x - ttW - 14;
          tooltip.style.left = Math.max(4, left) + 'px';
          tooltip.style.top = '12px';
        }
      });
      canvas.addEventListener('mouseleave', () => {
        if (tooltip) tooltip.setAttribute('hidden', '');
      });
    }

    /* ── Model computation ─────────────────────────────────────────── */
    function computeModel(annual, baselineKey) {
      const [bStart, bEnd] = BASELINE_RANGES[baselineKey] || [2000, 2029];
      const baselineElevs = annual
        .filter(d => d.year >= bStart && d.year <= bEnd)
        .map(d => d.mean_elev_m);
      if (!baselineElevs.length) return [];
      const baselineMean = mean(baselineElevs);
      return annual.map(d => ({
        year:   d.year,
        delta:  -ELR * (d.mean_elev_m - baselineMean),
      }));
    }

    /* ── Comparison chart ──────────────────────────────────────────── */
    let _compObserver = null;
    function drawCompChart(modelPts, obsPtsBySeries) {
      if (!modelPts || !obsPtsBySeries) return;
      const container = document.getElementById('compChartContainer');
      if (!container) return;
      if (_compObserver) { _compObserver.disconnect(); _compObserver = null; }
      const old = container.querySelector('canvas');
      if (old) old.remove();
      const canvas = document.createElement('canvas');
      canvas.style.cssText = 'display:block;width:100%;height:100%;cursor:crosshair';
      container.prepend(canvas);
      const tooltip = document.getElementById('compTooltip');
      const meta    = document.getElementById('compChartMeta');

      function draw() {
        const W = container.clientWidth || 600;
        const H = container.clientHeight || 220;
        const dpr = window.devicePixelRatio || 1;
        canvas.width  = Math.round(W * dpr);
        canvas.height = Math.round(H * dpr);
        canvas.style.width  = W + 'px';
        canvas.style.height = H + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colorModel = cssVar('--series-model') || '#d4a855';
        const colorObsRaw = cssVar('--series-obs') || '#5090f8';
        const colorObsAdj = cssVar('--series-obs-adjusted') || '#d45a4f';
        const textColor  = cssVar('--text-secondary') || '#a8a090';
        const gridColor  = 'rgba(212,168,85,0.12)';
        const pad = { top: 16, right: 24, bottom: 36, left: 64 };
        const cW = W - pad.left - pad.right;
        const cH = H - pad.top - pad.bottom;

        // Build common year range
        const obsRawMap = new Map((obsPtsBySeries.qcu || []).map(d => [d.year, d.anomaly_c]));
        const obsAdjMap = new Map((obsPtsBySeries.qcf || []).map(d => [d.year, d.anomaly_c]));
        const modMap = new Map(modelPts.map(d => [d.year, d.delta]));
        const allYrs = [...new Set([
          ...obsRawMap.keys(),
          ...obsAdjMap.keys(),
          ...modMap.keys(),
        ])].sort((a, b) => a - b);
        const minYr = allYrs[0], maxYr = allYrs[allYrs.length - 1];

        // Baseline-adjust observed series to the same reference period as the model
      const [bStart, bEnd] = BASELINE_RANGES[baseline] || [2000, 2029];
        const obsRawBaseline = mean(
          allYrs.filter(yr => yr >= bStart && yr <= bEnd && obsRawMap.has(yr)).map(yr => obsRawMap.get(yr))
        );
        const obsAdjBaseline = mean(
          allYrs.filter(yr => yr >= bStart && yr <= bEnd && obsAdjMap.has(yr)).map(yr => obsAdjMap.get(yr))
        );

        // Y range from visible data
        const allVals = [];
        if (observedRawVisible) {
          allYrs.forEach(yr => {
            if (obsRawMap.has(yr)) allVals.push(obsRawMap.get(yr) - (isNaN(obsRawBaseline) ? 0 : obsRawBaseline));
          });
        }
        if (observedAdjustedVisible) {
          allYrs.forEach(yr => {
            if (obsAdjMap.has(yr)) allVals.push(obsAdjMap.get(yr) - (isNaN(obsAdjBaseline) ? 0 : obsAdjBaseline));
          });
        }
        if (seriesModel) allYrs.forEach(yr => { if (modMap.has(yr)) allVals.push(modMap.get(yr)); });
        if (!allVals.length) { ctx.clearRect(0, 0, W, H); return; }
        const absMax = Math.max(Math.abs(Math.min(...allVals)), Math.abs(Math.max(...allVals)), 0.1);
        const hiD    = absMax * 1.1;
        const loD    = -absMax * 1.1;

        function xp(yr) { return pad.left + (yr - minYr) / Math.max(1, maxYr - minYr) * cW; }
        function yp(v)  { return pad.top  + (1 - (v - loD) / (hiD - loD)) * cH; }

        ctx.clearRect(0, 0, W, H);

        // Grid
        ctx.strokeStyle = gridColor;
        ctx.lineWidth = 1;
        for (let i = 0; i <= 4; i++) {
          const y = pad.top + (cH / 4) * i;
          ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left + cW, y); ctx.stroke();
        }

        // Zero line
        ctx.strokeStyle = 'rgba(212,168,85,0.35)';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 4]);
        ctx.beginPath(); ctx.moveTo(pad.left, yp(0)); ctx.lineTo(pad.left + cW, yp(0)); ctx.stroke();
        ctx.setLineDash([]);

        // Y labels
        ctx.fillStyle = textColor;
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'right';
        for (let i = 0; i <= 4; i++) {
          const v = hiD - (hiD - loD) * (i / 4);
          ctx.fillText(v.toFixed(2) + ' °C', pad.left - 6, pad.top + (cH / 4) * i + 4);
        }

        // X labels
        ctx.textAlign = 'center';
        const xStep = Math.ceil((maxYr - minYr) / 6 / 20) * 20 || 20;
        for (let yr = Math.ceil(minYr / xStep) * xStep; yr <= maxYr; yr += xStep) {
          ctx.fillText(yr, xp(yr), H - 8);
        }

        function drawSeries(map, baselineValue, color, width, dash) {
          if (!map.size) return;
          ctx.strokeStyle = color;
          ctx.lineWidth = width;
          ctx.lineJoin = 'round';
          ctx.setLineDash(dash || []);
          ctx.beginPath();
          let started = false;
          allYrs.forEach(yr => {
            if (!map.has(yr)) { started = false; return; }
            const v = map.get(yr) - (isNaN(baselineValue) ? 0 : baselineValue);
            if (!started) { ctx.moveTo(xp(yr), yp(v)); started = true; }
            else ctx.lineTo(xp(yr), yp(v));
          });
          ctx.stroke();
          ctx.setLineDash([]);
        }

        if (observedRawVisible) {
          drawSeries(obsRawMap, obsRawBaseline, colorObsRaw, 2, []);
        }
        if (observedAdjustedVisible) {
          drawSeries(obsAdjMap, obsAdjBaseline, colorObsAdj, 2, []);
        }

        // Model series
        if (seriesModel) {
          drawSeries(modMap, 0, colorModel, 1.5, []);
        }

        if (meta) meta.textContent = `baseline ${bStart}–${bEnd}`;
        return { xp, obsRawMap, obsAdjMap, modMap, obsRawBaseline, obsAdjBaseline };
      }

      let state = draw();
      _compObserver = new ResizeObserver(() => { state = draw(); });
      _compObserver.observe(container);

      canvas.addEventListener('mousemove', e => {
        if (!state || !tooltip) return;
        const { xp, obsRawMap, obsAdjMap, modMap, obsRawBaseline, obsAdjBaseline } = state;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const allYrs = [...new Set([...obsRawMap.keys(), ...obsAdjMap.keys(), ...modMap.keys()])].sort((a, b) => a - b);
        let best = null, bestDist = Infinity;
        allYrs.forEach(yr => {
          const dx = Math.abs(x - xp(yr));
          if (dx < bestDist) { bestDist = dx; best = yr; }
        });
        if (best !== null && bestDist < 30) {
          const lines = [`${best}`];
          if (observedRawVisible && obsRawMap.has(best)) {
            const v = obsRawMap.get(best) - (isNaN(obsRawBaseline) ? 0 : obsRawBaseline);
            lines.push(`Observed (Raw)  ${v >= 0 ? '+' : ''}${v.toFixed(3)} °C`);
          }
          if (observedAdjustedVisible && obsAdjMap.has(best)) {
            const v = obsAdjMap.get(best) - (isNaN(obsAdjBaseline) ? 0 : obsAdjBaseline);
            lines.push(`Observed (Adjusted)  ${v >= 0 ? '+' : ''}${v.toFixed(3)} °C`);
          }
          if (modMap.has(best)) {
            const v = modMap.get(best);
            lines.push(`Altitude signal  ${v >= 0 ? '+' : ''}${v.toFixed(4)} °C`);
          }
          tooltip.textContent = lines.join('\n');
          tooltip.removeAttribute('hidden');
          const ttW = tooltip.offsetWidth || 180;
          let left = x + 14;
          if (left + ttW > rect.width - 8) left = x - ttW - 14;
          tooltip.style.left = Math.max(4, left) + 'px';
          tooltip.style.top = '12px';
        }
      });
      canvas.addEventListener('mouseleave', () => {
        if (tooltip) tooltip.setAttribute('hidden', '');
      });
    }

    /* ── Observed anomaly fetch ─────────────────────────────────────── */
    async function fetchObservedAnomaly(ids, series) {
      const resp = await fetch(AGGREGATE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          station_ids:     ids,
          series:          series,
          geo_gridded:     true,
          full_years_only: true,
          anomaly_mode:    'auto_decade',
        }),
      });
      if (!resp.ok) throw new Error(`Aggregate API ${resp.status}`);
      const data = await resp.json();

      // Parse {start: "YYYY-MM", averages: [...monthly]}
      const [startYr, startMo] = data.start.split('-').map(Number);
      const monthly = data.averages || [];
      const byYear = new Map();
      monthly.forEach((v, i) => {
        const yr = startYr + Math.floor((startMo - 1 + i) / 12);
        if (!byYear.has(yr)) byYear.set(yr, []);
        if (typeof v === 'number' && isFinite(v)) byYear.get(yr).push(v);
      });
      const annual = [];
      byYear.forEach((vals, yr) => {
        if (vals.length >= 6) {   // require at least 6 months for an annual value
          annual.push({ year: yr, anomaly_c: mean(vals) });
        }
      });
      return annual.sort((a, b) => a.year - b.year);
    }

    async function preloadObservedAnomalies(ids) {
      const [qcu, qcf] = await Promise.all([
        fetchObservedAnomaly(ids, 'qcu'),
        fetchObservedAnomaly(ids, 'qcf'),
      ]);
      observedDataBySeries = { qcu, qcf };
      return observedDataBySeries;
    }

    /* ── Prediction UI ─────────────────────────────────────────────── */
    function renderPredictions() {
      const grid = document.getElementById('predictionGrid');
      if (!grid) return;

      // Shuffle per session (Math.random is session-scoped)
      const shuffled = [...PREDICTION_OPTIONS].sort(() => Math.random() - 0.5);

      shuffled.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'prediction-card' + (predictionKey === opt.key ? ' chosen' : '');
        btn.type = 'button';
        btn.dataset.key = opt.key;
        btn.innerHTML = `
          <span class="prediction-card-label">${opt.label}</span>
          <span class="prediction-card-desc">${opt.desc}</span>
        `;
        btn.addEventListener('click', () => onPredict(opt));
        grid.appendChild(btn);
      });
    }

    function onPredict(opt) {
      predictionKey = opt.key;
      pushStateToUrl();

      // Update card styles
      document.querySelectorAll('.prediction-card').forEach(c => {
        c.classList.toggle('chosen', c.dataset.key === opt.key);
      });

      // Show chosen banner
      const banner = document.getElementById('chosenBanner');
      const label  = document.getElementById('chosenLabel');
      if (banner && label) {
        label.textContent = opt.label;
        banner.removeAttribute('hidden');
      }

      // Hide "make a prediction" prompt
      const locked = document.getElementById('predictionLocked');
      if (locked) locked.hidden = true;

      // Reveal model section
      const modelSection = document.getElementById('model');
      if (modelSection && modelSection.hidden) {
        modelSection.removeAttribute('hidden');
        requestAnimationFrame(() => {
          modelSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        if (observedDataBySeries.qcu || observedDataBySeries.qcf) redrawCompChart();

        if (!modelBeaconSent && window.sendFeatureBeacon) {
          window.sendFeatureBeacon('labs/network-altitude/03-model-revealed');
          modelBeaconSent = true;
        }
      }

      if (!predBeaconSent && window.sendFeatureBeacon) {
        window.sendFeatureBeacon('labs/network-altitude/02-prediction-made');
        predBeaconSent = true;
      }
    }

    /* ── Baseline handling ─────────────────────────────────────────── */
    function setBaseline(key) {
      baseline = key;
      document.querySelectorAll('.baseline-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.baseline === key);
      });
      if (observedDataBySeries.qcu || observedDataBySeries.qcf) redrawCompChart();
      pushStateToUrl();
    }

    function redrawCompChart() {
      if (!altitudeData || (!observedDataBySeries.qcu && !observedDataBySeries.qcf)) return;
      const compSection  = document.getElementById('comparison');
      const compLoading  = document.getElementById('compChartLoading');
      const compPrompt   = document.getElementById('comparisonPrompt');
      if (compPrompt) compPrompt.hidden = true;
      if (compSection && compSection.hidden) {
        compSection.removeAttribute('hidden');
        if (!compBeaconSent && window.sendFeatureBeacon) {
          window.sendFeatureBeacon('labs/network-altitude/04-comparison-revealed');
          compBeaconSent = true;
        }
      }
      if (compLoading) compLoading.hidden = true;
      const modelPts = computeModel(altitudeData.annual, baseline);
      drawCompChart(modelPts, observedDataBySeries);
    }

    /* ── Legend toggles ────────────────────────────────────────────── */
    function wireLegend() {
      const btnObsRaw = document.getElementById('legendObsRaw');
      const btnObsAdj = document.getElementById('legendObsAdj');
      const btnModel  = document.getElementById('legendModel');
      const modelColor = cssVar('--series-model') || '#d4a855';
      const obsRawColor = cssVar('--series-obs') || '#5090f8';
      const obsAdjColor = cssVar('--series-obs-adjusted') || '#d45a4f';
      const offBorder = cssVar('--border') || 'rgba(255,255,255,0.28)';

      function updateLegendStyles() {
        if (btnObsRaw) {
          btnObsRaw.style.borderColor = observedRawVisible ? obsRawColor : offBorder;
          btnObsRaw.classList.toggle('series-off', !observedRawVisible);
        }
        if (btnObsAdj) {
          btnObsAdj.style.borderColor = observedAdjustedVisible ? obsAdjColor : offBorder;
          btnObsAdj.classList.toggle('series-off', !observedAdjustedVisible);
        }
        if (btnModel) {
          btnModel.style.borderColor = seriesModel ? modelColor : offBorder;
          btnModel.classList.toggle('series-off', !seriesModel);
        }
      }

      if (btnObsRaw) {
        btnObsRaw.addEventListener('click', () => {
          observedRawVisible = !observedRawVisible;
          updateLegendStyles();
          pushStateToUrl();
          if (altitudeData && (observedDataBySeries.qcu || observedDataBySeries.qcf)) redrawCompChart();
        });
      }
      if (btnObsAdj) {
        btnObsAdj.addEventListener('click', () => {
          observedAdjustedVisible = !observedAdjustedVisible;
          updateLegendStyles();
          pushStateToUrl();
          if (altitudeData && (observedDataBySeries.qcu || observedDataBySeries.qcf)) redrawCompChart();
        });
      }
      if (btnModel) {
        btnModel.addEventListener('click', () => {
          seriesModel = !seriesModel;
          updateLegendStyles();
          pushStateToUrl();
          if (altitudeData && (observedDataBySeries.qcu || observedDataBySeries.qcf)) redrawCompChart();
        });
      }
      updateLegendStyles();
    }

    /* ── Reset ─────────────────────────────────────────────────────── */
    function wireReset() {
      const btn = document.getElementById('resetLab');
      if (!btn) return;
      btn.addEventListener('click', () => {
        predictionKey = null;
        baseline      = '2000-2029';
        observedRawVisible      = false;
        observedAdjustedVisible = false;
        seriesModel             = true;

        document.querySelectorAll('.prediction-card').forEach(c => c.classList.remove('chosen'));
        const banner = document.getElementById('chosenBanner');
        if (banner) banner.setAttribute('hidden', '');
        const locked = document.getElementById('predictionLocked');
        if (locked) locked.hidden = false;

        const modelSection = document.getElementById('model');
        if (modelSection) modelSection.setAttribute('hidden', '');
        const compSection  = document.getElementById('comparison');
        if (compSection)  compSection.setAttribute('hidden', '');

        document.querySelectorAll('.baseline-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.baseline === '2000-2029');
        });
        wireLegend();

        pushStateToUrl();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    /* ── Theme toggle ──────────────────────────────────────────────── */
    function wireTheme() {
      const btn = document.getElementById('themeToggle');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'light' ? 'dark' : 'light';
        if (next === 'dark') document.documentElement.removeAttribute('data-theme');
        else document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('klymot-theme', next);
        // Redraw charts to pick up new CSS variable values
        if (altitudeData) drawAltitudeChart(altitudeData.annual);
        if (observedDataBySeries.qcu || observedDataBySeries.qcf) redrawCompChart();
      });
    }

    /* ── Initialisation ────────────────────────────────────────────── */
    async function initialize() {
      // Restore URL state
      const urlState = readStateFromUrl();
      if (urlState.baseline && BASELINE_RANGES[urlState.baseline]) baseline = urlState.baseline;
      if (urlState.obs) {
        const parts = new Set(urlState.obs.split(',').map(s => s.trim()).filter(Boolean));
        observedRawVisible = parts.has('qcu') || parts.has('raw');
        observedAdjustedVisible = parts.has('qcf') || parts.has('adjusted');
        if (urlState.obs === 'none') {
          observedRawVisible = false;
          observedAdjustedVisible = false;
        }
      }
      const initialPredKey = urlState.prediction;
      if (urlState.series) {
        const parts = urlState.series.split(',').map(s => s.trim()).filter(Boolean);
        seriesModel = parts.includes('model');
        if (urlState.series === 'none') seriesModel = false;
      }

      wireTheme();
      wireReset();
      wireLegend();

      // Baseline buttons
      document.querySelectorAll('.baseline-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.baseline === baseline);
        btn.addEventListener('click', () => setBaseline(btn.dataset.baseline));
      });

      // Render prediction cards
      renderPredictions();

      // Restore prediction from URL
      if (initialPredKey) {
        const opt = PREDICTION_OPTIONS.find(o => o.key === initialPredKey);
        if (opt) {
          // Don't scroll on load
          predictionKey = opt.key;
          document.querySelectorAll('.prediction-card').forEach(c => {
            c.classList.toggle('chosen', c.dataset.key === opt.key);
          });
          const banner = document.getElementById('chosenBanner');
          const label  = document.getElementById('chosenLabel');
          if (banner && label) { label.textContent = opt.label; banner.removeAttribute('hidden'); }
          const locked = document.getElementById('predictionLocked');
          if (locked) locked.hidden = true;
          const modelSection = document.getElementById('model');
          if (modelSection) modelSection.removeAttribute('hidden');
        }
      }

      const altitudePromise = (async () => {
        const resp = await fetch(DATA_BASE + '/network-altitude.json');
        if (!resp.ok) throw new Error(resp.status);
        return resp.json();
      })();

      const stationIdsPromise = (async () => {
        const resp = await fetch(DATA_BASE + '/station-ids.json');
        if (!resp.ok) throw new Error(resp.status);
        const idsData = await resp.json();
        return idsData.station_ids;
      })();

      const observedPromise = stationIdsPromise.then(ids => {
        stationIds = ids;
        const compPrompt = document.getElementById('comparisonPrompt');
        if (compPrompt) compPrompt.querySelector('p').textContent = 'Fetching observed data…';
        return preloadObservedAnomalies(ids);
      });

      try {
        altitudeData = await altitudePromise;
        const loading = document.getElementById('altitudeChartLoading');
        if (loading) loading.hidden = true;
        drawAltitudeChart(altitudeData.annual);
      } catch (err) {
        const loading = document.getElementById('altitudeChartLoading');
        if (loading) loading.textContent = 'Could not load altitude data.';
        console.error('Altitude data load error:', err);
      }

      try {
        await observedPromise;
        const compPrompt = document.getElementById('comparisonPrompt');
        if (altitudeData && initialPredKey) {
          redrawCompChart();
        } else if (compPrompt) {
          compPrompt.querySelector('p').textContent = 'Make your prediction above to see the comparison.';
        }
      } catch (err) {
        const compPrompt = document.getElementById('comparisonPrompt');
        if (compPrompt) compPrompt.querySelector('p').textContent = 'Could not load observed data.';
        console.error('Observed anomaly load error:', err);
      }

      pushStateToUrl();

      // Analytics
      if (!visitBeaconSent && window.sendFeatureBeacon) {
        window.sendFeatureBeacon('labs/network-altitude/01-visited');
        visitBeaconSent = true;
      }
    }

    document.addEventListener('DOMContentLoaded', initialize);

  }());
  </script>

</body>
